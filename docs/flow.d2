# AI CRM Agent - Conversation Flow (Write Path)
# Render: d2 --theme 303 --sketch --pad 120 --scale 1.5 --layout dagre

shape: sequence_diagram

user: User
ui: Chat UI
agent: Agent
claude: Claude
mcp: MCP Server
crm: CRM API

user -> ui: "1. Mark Acme as closed-won"
ui -> agent: "2. Message + memory"
agent -> claude: "3. Prompt + tools"
claude -> agent: "4. Tool call: update_stage"
agent -> mcp: "5. Draft update (not committed)"
mcp -> ui: "6. Confirm this change?"
user -> ui: "7. Confirm"
ui -> agent: "8. Commit"
agent -> crm: "9. PATCH /contacts/:id" {
  style.stroke: "#059669"
  style.bold: true
}
crm -> user: "10. Acme updated"
