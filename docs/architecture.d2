# AI CRM Agent - Architecture
# Render: d2 --theme 0 --sketch --pad 80 --scale 1.0 --layout elk docs/architecture.d2 docs/architecture.svg

vars: {
  d2-config: {
    theme-id: 0
  }
}

direction: right
grid-columns: 3
grid-gap: 120

classes: {
  card: {
    width: 160
    height: 160
    style.font-size: 14
  }
  zone: {
    style.fill: "#f8fafc"
    style.stroke: "#cbd5e1"
    style.stroke-width: 2
    style.border-radius: 12
    style.shadow: true
    style.font-size: 13
    style.bold: true
  }
  hidden: {
    style.fill: transparent
    style.stroke: transparent
  }
}

# 3x3 hub-and-spoke layout. app_zone at dead center [1,1].
# Row 0: _    | user  | _
# Row 1: data | app   | integrations
# Row 2: _    | agent | _

spacer_tl: "" { class: hidden }

user_slot: "" { class: hidden
  user: Internal User {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/user-round.svg
  }
}

spacer_tr: "" { class: hidden }

data_zone: "Data" {
  db: Postgres + pgvector {
    class: card
    icon: https://cdn.simpleicons.org/postgresql
  }
}

app_zone: "App" {
  grid-columns: 2
  grid-gap: 30

  ui: Next.js Chat UI {
    class: card
    icon: https://cdn.simpleicons.org/nextdotjs
  }
  orchestrator: FastAPI Orchestrator {
    class: card
    icon: https://cdn.simpleicons.org/fastapi
  }
}

integrations_zone: "3rd Party Integrations" {
  grid-columns: 2
  grid-gap: 30

  claude: Claude API {
    class: card
    icon: https://cdn.simpleicons.org/anthropic
  }
  crm: HubSpot / Salesforce {
    class: card
    icon: https://cdn.simpleicons.org/hubspot
  }
}

spacer_bl: "" { class: hidden }

agent_zone: "Agent Runtime" {
  grid-columns: 3
  grid-gap: 30

  memory: Memory Manager {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/brain.svg
  }
  reads: Read Tools {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/eye.svg
  }
  writes: Write Guardrail {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/shield-check.svg
  }
}

spacer_br: "" { class: hidden }

user_slot.user -> app_zone.ui: "1. Message"
app_zone.ui -> app_zone.orchestrator: "2. Request"
app_zone.orchestrator -> data_zone.db: "3. Load session"
app_zone.orchestrator -> agent_zone.memory: "4. Build context"
app_zone.orchestrator -> agent_zone.reads: "5. Fetch"
app_zone.orchestrator -> agent_zone.writes: "6. Mutate"
agent_zone.reads -> integrations_zone.crm: "7. Read CRM"
agent_zone.writes -> integrations_zone.crm: "8. Commit write" {
  style.stroke: "#059669"
  style.bold: true
}
app_zone.orchestrator -> integrations_zone.claude: "LLM call" {
  style.stroke-dash: 3
}
