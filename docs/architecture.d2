# AI CRM Agent - Architecture
# Render: d2 --theme 0 --sketch --pad 80 --scale 1.0 --layout elk docs/architecture.d2 docs/architecture.svg

vars: {
  d2-config: {
    theme-id: 0
  }
}

direction: right
grid-columns: 3
grid-gap: 60

classes: {
  card: {
    width: 160
    height: 160
    style.font-size: 14
  }
  zone: {
    style.fill: "#f8fafc"
    style.stroke: "#cbd5e1"
    style.stroke-width: 2
    style.border-radius: 12
    style.shadow: true
    style.font-size: 13
    style.bold: true
  }
}

# Entry point - outside the system
user: Internal User {
  class: card
  icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/user-round.svg
}

client_zone: "Client" {
  ui: Next.js Chat UI {
    class: card
    icon: https://cdn.simpleicons.org/nextdotjs
  }
}

agent_core_zone: "Agent Core" {
  grid-columns: 2
  grid-gap: 30

  orchestrator: Claude Orchestrator {
    class: card
    icon: https://cdn.simpleicons.org/anthropic
  }
  memory: Memory Manager {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/brain.svg
  }
}

mcp_zone: "MCP Tool Layer" {
  grid-columns: 2
  grid-gap: 30

  reads: Read Tools {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/eye.svg
  }
  writes: Write Guardrail {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/shield-check.svg
  }
}

data_zone: "Data" {
  db: Postgres + pgvector {
    class: card
    icon: https://cdn.simpleicons.org/postgresql
  }
}

integrations_zone: "3rd Party Integrations" {
  crm: HubSpot / Salesforce {
    class: card
    icon: https://cdn.simpleicons.org/hubspot
  }
}

# Clean flow: orchestrator routes through mcp_zone, writes confirm via ui before commit
user -> client_zone.ui: "1. Message"
client_zone.ui -> agent_core_zone.orchestrator: "2. Request"
agent_core_zone.orchestrator -> agent_core_zone.memory: "3. Load context"
agent_core_zone.memory -> data_zone.db: "4. Session state"
agent_core_zone.orchestrator -> mcp_zone: "5. Tool call"
mcp_zone.reads -> integrations_zone.crm: "6. Read CRM"
mcp_zone.writes -> client_zone.ui: "7. Confirm change?"
mcp_zone.writes -> integrations_zone.crm: "8. On confirm" {
  style.stroke: "#059669"
  style.bold: true
}
