# AI CRM Agent - Architecture
# Render: d2 --theme 303 --sketch --pad 120 --scale 1.5 --layout elk

direction: down

user: "Internal User" {
  icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/user-round.svg
}

ui: Chat UI {
  icon: https://cdn.simpleicons.org/nextdotjs
}

agent: "Agent Runtime" {
  style.bold: true

  orchestrator: Claude Orchestrator {
    icon: https://cdn.simpleicons.org/anthropic
  }
  memory: Memory Manager {
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/brain.svg
  }
  guard: Write Guardrail {
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/shield-check.svg
  }
}

mcp: "MCP Server" {
  style.bold: true

  reads: "Read Tools\n(get, search, history)" {
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/eye.svg
  }
  writes: "Write Tools\n(confirmation-gated)" {
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/pencil.svg
  }
}

data: "Data Layer" {
  style.bold: true

  memory_db: "Memory + Drafts" {
    icon: https://cdn.simpleicons.org/postgresql
  }
  audit: "Immutable Audit Log" {
    icon: https://icons.terrastruct.com/aws%2FStorage%2FAmazon-Simple-Storage-Service-S3.svg
  }
}

external: "External" {
  style.bold: true

  claude: Anthropic Claude {
    icon: https://cdn.simpleicons.org/anthropic
  }
  crm: CRM API {
    icon: https://cdn.simpleicons.org/hubspot
  }
}

user -> ui
ui -> agent.orchestrator
agent.orchestrator -> agent.memory
agent.memory -> data.memory_db
agent.orchestrator -> external.claude: "Prompt + tools"
agent.orchestrator -> mcp.reads
agent.orchestrator -> mcp.writes
agent.orchestrator -> agent.guard
agent.guard -> ui: "Confirm draft"
mcp.reads -> external.crm
mcp.writes -> external.crm: "On user confirm"
mcp.reads -> data.audit
mcp.writes -> data.audit
