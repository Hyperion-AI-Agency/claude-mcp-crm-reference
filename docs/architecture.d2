# AI CRM Agent - Architecture
# Render: d2 --theme 303 --sketch --pad 120 --scale 1.5 --layout elk

direction: right
grid-columns: 2
grid-gap: 40

classes: {
  card: {
    width: 220
    height: 140
  }
}

user: Internal User {
  class: card
  icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/user-round.svg
}

ui: Next.js Chat UI {
  class: card
  icon: https://cdn.simpleicons.org/nextdotjs
}

agent: Agent Runtime {
  style.bold: true

  orchestrator: Claude Orchestrator {
    class: card
    icon: https://cdn.simpleicons.org/anthropic
  }
  memory: Memory Manager {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/brain.svg
  }
}

mcp: MCP Server {
  style.bold: true

  reads: Read Tools {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/eye.svg
  }
  writes: Write Tools {
    class: card
    icon: https://cdn.jsdelivr.net/npm/lucide-static@latest/icons/shield-check.svg
  }
}

db: Postgres {
  class: card
  icon: https://cdn.simpleicons.org/postgresql
}

crm: CRM API {
  class: card
  icon: https://cdn.simpleicons.org/hubspot
}

user -> ui: "1. Message"
ui -> agent.orchestrator: "2. Request"
agent.orchestrator -> agent.memory: "3. Load context"
agent.memory -> db: "4. Session + user state"
agent.orchestrator -> mcp.reads: "5. Tool call (fetch)"
mcp.reads -> crm: "6. GET /contacts"
agent.orchestrator -> mcp.writes: "7. Tool call (mutate)"
mcp.writes -> db: "8. Save draft"
mcp.writes -> ui: "9. Confirm?"
mcp.writes -> crm: "10. On confirm" {
  style.stroke: "#059669"
  style.bold: true
}
